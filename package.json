{
  "name": "virtual-warehouse-app",
  "version": "0.2.0",
  "private": true,
  "description": "Live warehouse stock visualiser, fed by Peoplevox WMS",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "start": "node server/index.js",
    "sync:once": "node server/sync.js --once",
    "dev": "node --watch server/index.js",
    "web:install": "npm --prefix web ci || npm --prefix web install",
    "web:build": "npm --prefix web run build",
    "web:dev": "npm --prefix web run dev",
    "build": "npm run web:install && npm run web:build",
    "postinstall": "npm run web:install"
  },
  "dependencies": {
    "express": "^4.21.1",
    "fast-xml-parser": "^4.5.0",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.13.1"
  }
}
