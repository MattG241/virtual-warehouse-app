# Copy to .env for local dev. On Railway, set these as service variables.

# --- Postgres ---
# Railway injects DATABASE_URL automatically when you attach a Postgres plugin.
# For local dev, point this at your own Postgres.
DATABASE_URL=postgres://user:pass@localhost:5432/virtual_warehouse

# --- Peoplevox API ---
# Base URL of your PVX integration service. Note the regional host (ap.* for AU).
PVX_URL=https://ap.peoplevox.net/ryd1039/resources/integrationservicev4.asmx
PVX_CLIENT_ID=ryd1039
PVX_USERNAME=Customer Service
# Base64-encoded password. Locally:  printf '%s' 'yourpassword' | base64
PVX_PASSWORD_B64=

# Report template name and columns (these are correct for ryd1039 as of 2026-05).
PVX_TEMPLATE=Item inventory by location
PVX_COLUMNS=[Item Code],[Name],[Stock Count],[Container Barcode],[Location barcode],[Site reference],[Location type],[Item type group]

# --- Sync worker ---
# How often to re-pull from PVX. 5 min = 300000 ms.
SYNC_INTERVAL_MS=300000
# Rows per page. Don't push past 1000 unless you've tested for timeouts.
SYNC_PAGE_SIZE=1000
# Pause between pages to stay well under the 15-req/15-sec rate limit.
SYNC_PAGE_DELAY_MS=400

# --- Server ---
PORT=3000

# --- Auth ---
# Required: long random string used to sign session JWTs. Generate with
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET=

# Comma-separated list of emails allowed to sign in. Use * to allow any.
ALLOWED_EMAILS=matthew@ryderwear.com.au

# Resend API key for sending sign-in emails (https://resend.com).
# If unset, magic links are printed to the server logs instead.
RESEND_API_KEY=

# Sender for sign-in emails. Default works without DNS setup but emails come
# from a Resend test sender. Verify your own domain in Resend for branded mail.
RESEND_SENDER=onboarding@resend.dev

# Public URL of your deployment (used to build magic-link redirects). Optional;
# inferred from request headers if absent.
APP_URL=

NODE_ENV=development
